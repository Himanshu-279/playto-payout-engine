# ── Django ─────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# ── Supabase Database ──────────────────────────────
# Supabase Dashboard → Settings → Database → URI (Connection pooling wala)
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DB_SSL=True

# ── Upstash Redis ──────────────────────────────────
# Upstash Dashboard → Redis → Connect → .env copy karo
REDIS_URL=rediss://default:[YOUR-PASSWORD]@[YOUR-HOST].upstash.io:6379
